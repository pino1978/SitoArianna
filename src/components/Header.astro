---
import navigation from "../data/navigation.json";
import logo from "../assets/svg/logo-arianna-milano.svg";
import yingHeaderMark from "../assets/images/ying-header-mark.png";

const currentPath = Astro.url.pathname;
const isActive = (href) => {
  if (href.includes("#")) return false;
  return href === "/" ? currentPath === "/" : currentPath.startsWith(href);
};
---
<header class="site-header" data-header>
  <a class="brand-mark" href="/" aria-label="Arianna Milano, torna alla Home">
    <img src={logo.src} alt="Arianna Milano" width={logo.width} height={logo.height} />
  </a>

  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation">
    <span class="sr-only">Apri menu</span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>

  <nav class="primary-nav" id="primary-navigation" aria-label="Navigazione principale">
    {navigation.map((item) => (
      <a href={item.href} class:list={{ "is-active": isActive(item.href) }} aria-current={isActive(item.href) ? "page" : undefined}>
        <span class="nav-icon" aria-hidden="true">
          {item.label === "Home" && <svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5v8a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z" /></svg>}
          {item.label === "Highlights" && <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m10 9 5 3-5 3z" /></svg>}
          {item.label === "Profilo" && <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3.5" /><path d="M5 20c.7-4 3-6 7-6s6.3 2 7 6" /></svg>}
          {item.label === "Yīng" && <svg viewBox="0 0 24 24"><path d="M4 13c4-1 6-4 8-8 1.5 3 4 5 8 6-3 1-5 3-6 6l-2-3-3 4-1-4z" /><path d="M12 14v6" /></svg>}
          {item.label === "Risultati" && <svg viewBox="0 0 24 24"><path d="M8 4h8v5a4 4 0 0 1-8 0zM9 20h6M12 13v7M8 6H4v2a4 4 0 0 0 4 4M16 6h4v2a4 4 0 0 1-4 4" /></svg>}
          {item.label === "Media" && <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" /><circle cx="9" cy="10" r="2" /><path d="m5 17 4-4 3 3 2-2 5 3" /></svg>}
          {item.label === "Contatti" && <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m4 7 8 6 8-6" /></svg>}
        </span>
        <span class="nav-label">{item.label}</span>
      </a>
    ))}

    <div class="mobile-nav-footer" aria-hidden="true">
      <div class="mobile-nav-footer__line"></div>
      <img src={yingHeaderMark.src} alt="" width={yingHeaderMark.width} height={yingHeaderMark.height} />
      <p class="mobile-nav-footer__signature">Yīng <span>·</span> 鹰</p>
      <small>Arianna Milano</small>
    </div>
  </nav>

  <img class="ying-header-mark" src={yingHeaderMark.src} alt="" aria-hidden="true" width={yingHeaderMark.width} height={yingHeaderMark.height} />

  <label class="language-select">
    <span class="sr-only">Lingua</span>
    <select aria-label="Seleziona lingua">
      <option value="it" selected>IT</option>
      <option value="en">EN</option>
    </select>
  </label>
</header>
<div class="menu-backdrop" data-menu-backdrop aria-hidden="true"></div>

<style is:global>
  .nav-icon { display: none; }
  .menu-backdrop { display: none; }
  .mobile-nav-footer { display: none; }

  @media (max-width: 640px) {
    .menu-backdrop {
      position: fixed;
      z-index: 19;
      inset: 0;
      display: block;
      background:
        linear-gradient(90deg,
          rgba(0, 0, 0, 0.03) 0%,
          rgba(26, 18, 10, 0.08) 38%,
          rgba(64, 42, 18, 0.18) 68%,
          rgba(8, 7, 6, 0.34) 100%);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 220ms ease, visibility 0s linear 220ms;
    }

    body.menu-open .menu-backdrop {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition-delay: 0s;
    }

    .primary-nav {
      top: 0 !important;
      right: 0 !important;
      bottom: 0 !important;
      width: min(54vw, 228px) !important;
      height: 100svh !important;
      min-height: 100svh !important;
      max-height: 100svh !important;
      padding: 78px 18px max(18px, env(safe-area-inset-bottom)) !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-start !important;
      align-content: stretch !important;
      gap: 0 !important;
      overflow-y: auto;
      border-radius: 12px 0 0 12px;
    }

    .primary-nav::before {
      top: 20%;
      height: 42px;
    }

    .primary-nav::after {
      display: none;
    }

    .primary-nav a {
      flex: 0 0 auto !important;
      grid-template-columns: 28px 1fr !important;
      column-gap: 10px !important;
      min-height: 50px !important;
      height: 50px !important;
      margin: 0 !important;
      padding: 0 0 0 2px !important;
      font-size: 0.7rem !important;
      letter-spacing: 0.11em !important;
    }

    .primary-nav .nav-icon {
      width: 24px !important;
      height: 24px !important;
    }

    .primary-nav .nav-icon svg {
      width: 21px !important;
      height: 21px !important;
    }

    .primary-nav a::after {
      left: 38px;
    }

    .primary-nav a:first-child {
      color: rgba(247, 240, 228, 0.92);
    }

    .primary-nav a:first-child::after {
      transform: scaleX(0);
    }

    .primary-nav a.is-active {
      color: var(--gold-bright);
    }

    .primary-nav a.is-active::after {
      display: block;
      transform: scaleX(1);
    }

    .mobile-nav-footer {
      display: flex;
      margin-top: auto;
      padding-top: 20px;
      flex-direction: column;
      align-items: flex-start;
      position: relative;
      min-height: 118px;
      overflow: hidden;
    }

    .mobile-nav-footer__line {
      width: 42px;
      height: 1px;
      margin-bottom: 14px;
      background: linear-gradient(90deg, rgba(196, 157, 93, 0.9), rgba(196, 157, 93, 0));
    }

    .mobile-nav-footer img {
      position: absolute;
      right: -16px;
      bottom: -24px;
      width: 112px;
      height: auto;
      opacity: 0.075;
      filter: saturate(0.75);
      pointer-events: none;
    }

    .mobile-nav-footer__signature,
    .mobile-nav-footer small {
      position: relative;
      z-index: 1;
      margin: 0;
    }

    .mobile-nav-footer__signature {
      color: rgba(247, 240, 228, 0.88);
      font-family: var(--font-display, serif);
      font-size: 1rem;
      line-height: 1.2;
      letter-spacing: 0.08em;
      text-transform: none;
    }

    .mobile-nav-footer__signature span {
      color: rgba(196, 157, 93, 0.82);
      padding: 0 0.12em;
    }

    .mobile-nav-footer small {
      margin-top: 7px;
      color: rgba(247, 240, 228, 0.42);
      font-size: 0.54rem;
      line-height: 1.4;
      letter-spacing: 0.13em;
      text-transform: uppercase;
    }
  }

  @media (max-width: 390px) {
    .primary-nav {
      width: min(58vw, 210px) !important;
      padding: 72px 16px max(14px, env(safe-area-inset-bottom)) !important;
    }

    .primary-nav a {
      min-height: 48px !important;
      height: 48px !important;
      font-size: 0.68rem !important;
    }

    .mobile-nav-footer {
      min-height: 104px;
      padding-top: 16px;
    }
  }
</style>

<script>
  const header = document.querySelector("[data-header]");
  const toggle = header?.querySelector(".nav-toggle");
  const nav = header?.querySelector(".primary-nav");
  const backdrop = document.querySelector("[data-menu-backdrop]");
  let scrollPosition = 0;

  const setMenuState = (open) => {
    toggle?.setAttribute("aria-expanded", String(open));
    nav?.toggleAttribute("data-open", open);

    if (open) {
      scrollPosition = window.scrollY;
      document.body.style.top = `-${scrollPosition}px`;
      document.body.classList.add("menu-open");
    } else {
      document.body.classList.remove("menu-open");
      document.body.style.top = "";
      window.scrollTo(0, scrollPosition);
    }
  };

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setMenuState(!isOpen);
  });

  backdrop?.addEventListener("click", () => setMenuState(false));

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuState(false));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && toggle?.getAttribute("aria-expanded") === "true") {
      setMenuState(false);
      toggle.focus();
    }
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth > 640 && toggle?.getAttribute("aria-expanded") === "true") {
      setMenuState(false);
    }
  });
</script>
