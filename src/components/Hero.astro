---
import Header from "./Header.astro";
import StatsStrip from "./StatsStrip.astro";
import results from "../data/results.json";
import heroImage from "../assets/images/hero-ary14.png";
import heroEagleLayerImage from "../assets/images/hero-eagle-layer-aq2.png";
---
<section class="hero" id="top" aria-labelledby="hero-title" style={`--hero-bg: url("${heroImage.src}")`}>
  <div class="hero-overlay hero-overlay-left" aria-hidden="true"></div>
  <div class="hero-overlay hero-overlay-right" aria-hidden="true"></div>
  <div class="hero-overlay hero-overlay-bottom" aria-hidden="true"></div>
  <div class="hero-overlay hero-overlay-top" aria-hidden="true"></div>

  <Header />

  <div class="hero-upper-signature" aria-hidden="true">
    <span class="hero-upper-signature__eyebrow">Yīng · 鹰</span>
    <img class="hero-upper-signature__eagle" src={heroEagleLayerImage.src} alt="" width={heroEagleLayerImage.width} height={heroEagleLayerImage.height} />
    <strong>Sanda<br />Athlete</strong>
    <span class="hero-upper-signature__meta">Kasoria · -40 kg</span>
  </div>

  <div class="hero-copy">
    <h1 id="hero-title" class="sr-only">Arianna Milano, atleta di Sanda</h1>
    <p class="hero-subcopy">Ogni giorno, un passo avanti.<br /><strong>Sanda is my way.</strong></p>
    <a class="hero-cta" href="#profilo">Scopri il mio percorso <span aria-hidden="true">-&gt;</span></a>
    <StatsStrip stats={results.heroStats} />
  </div>

  <img class="hero-eagle-layer" src={heroEagleLayerImage.src} alt="" aria-hidden="true" width={heroEagleLayerImage.width} height={heroEagleLayerImage.height} />
</section>

<section class="hero-values" aria-label="I valori di Arianna">
  <div class="hero-values__inner">
    <span>Disciplina</span>
    <span>Coraggio</span>
    <strong>Libertà</strong>
    <span>Crescita</span>
  </div>
</section>
