---
import media from "../data/media.json";

const imageModules = import.meta.glob("../assets/images/*.png", { eager: true });

function imageFor(fileName) {
  const key = `../assets/images/${fileName}`;
  return imageModules[key]?.default;
}

const highlights = [
  {
    title: "World Open Championship",
    meta: "Finale - Perugia",
    duration: "03:12",
    image: media[1],
  },
  {
    title: "Champion Cup",
    meta: "Semifinale - Sora",
    duration: "02:45",
    image: media[2],
  },
  {
    title: "Allenamento tecnico",
    meta: "Preparazione Sanda",
    duration: "04:08",
    image: media[0],
  },
  {
    title: "Focus gara",
    meta: "Percorso agonistico",
    duration: "02:31",
    image: media[3],
  },
];
---
<section class="highlights-strip" aria-labelledby="highlights-title">
  <div class="section-head compact">
    <p>Highlights</p>
    <h2 id="highlights-title">I momenti che contano</h2>
    <a href="#media">Vai a tutti i video <span aria-hidden="true">-&gt;</span></a>
  </div>

  <div class="highlight-rail">
    {highlights.map((item) => {
      const image = imageFor(item.image.image);
      return (
        <article class="highlight-card">
          <a href="#media" aria-label={`Apri ${item.title}`}>
            <img src={image.src} alt={item.image.alt} loading="lazy" width={image.width} height={image.height} />
            <span class="play-badge" aria-hidden="true"></span>
            <time>{item.duration}</time>
          </a>
          <h3>{item.title}</h3>
          <p>{item.meta}</p>
        </article>
      );
    })}
  </div>
</section>
