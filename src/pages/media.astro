---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import placeholderA from "../assets/images/discipline-placeholder.png";
import placeholderB from "../assets/images/sanda-placeholder.png";
import placeholderC from "../assets/images/profile-portrait-placeholder.png";
const placeholders = [
  { image: placeholderA, label: "Allenamenti", year: "2026" },
  { image: placeholderB, label: "Gare", year: "2026" },
  { image: placeholderC, label: "Ritratto atleta", year: "2026" },
  { image: placeholderB, label: "Podi", year: "2026" },
  { image: placeholderA, label: "Eventi", year: "2026" },
  { image: placeholderC, label: "Backstage", year: "2026" }
];
---
<BaseLayout title="Media | Arianna Milano" description="Foto, video, gare e allenamenti di Arianna Milano, atleta di Sanda.">
  <main id="main" class="media-page">
    <section class="page-hero"><Header /><div><p class="eyebrow">Media</p><h1>Foto & Video</h1><p>Uno spazio editoriale dedicato ad allenamenti, competizioni, podi ed eventi.</p></div></section>
    <section class="media-content">
      <div class="section-heading"><p class="eyebrow">Gallery fotografica</p><h2>Archivio immagini</h2><p>Le immagini presenti sono segnaposto. Verranno sostituite con fotografie reali selezionate e autorizzate.</p></div>
      <div class="filters" aria-label="Filtri gallery"><button type="button" aria-pressed="true">Tutti</button><button type="button">Allenamenti</button><button type="button">Gare</button><button type="button">Podi</button><button type="button">Eventi</button></div>
      <div class="gallery-grid">{placeholders.map((item) => <article><img src={item.image.src} alt={`Segnaposto per la sezione ${item.label}`} width={item.image.width} height={item.image.height} loading="lazy" /><div><span>{item.year}</span><h3>{item.label}</h3></div></article>)}</div>
    </section>
    <section class="video-section"><div class="section-heading"><p class="eyebrow">Video</p><h2>Highlights e incontri</h2><p>I video YouTube ufficiali saranno inseriti qui con titolo, data e descrizione.</p></div><div class="video-grid">{[1,2,3].map((item) => <article class="video-placeholder"><span aria-hidden="true">▶</span><h3>Video highlight {item}</h3><p>Segnaposto per contenuto YouTube</p></article>)}</div></section>
  </main>
  <style>
    .media-page{background:#080706;color:#f5f0e7}.page-hero{min-height:430px;padding:150px max(28px,calc((100vw - 1160px)/2)) 70px;background:radial-gradient(circle at 80% 18%,rgba(185,134,50,.18),transparent 30%),linear-gradient(135deg,#080706,#17130f);position:relative}.page-hero .site-header{position:absolute;top:0;left:50%;transform:translateX(-50%)}h1,h2,h3{font-family:var(--font-display);text-transform:uppercase;line-height:.95}.page-hero h1{font-size:clamp(3rem,8vw,7rem);margin:.2em 0}.page-hero>div>p:last-child{max-width:620px;font-size:1.15rem}.eyebrow{color:var(--gold-bright);font-family:var(--font-ui);font-size:.72rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase}.media-content,.video-section{padding:90px max(28px,calc((100vw - 1160px)/2))}.media-content{background:var(--ivory);color:var(--ink)}.section-heading{max-width:760px;margin-bottom:36px}.section-heading h2{font-size:clamp(2.2rem,5vw,4.8rem);margin:.2em 0}.section-heading>p:last-child{line-height:1.7}.filters{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:28px}.filters button{border:1px solid rgba(8,7,6,.25);background:transparent;padding:10px 15px;font:inherit;text-transform:uppercase;font-size:.68rem;letter-spacing:.1em}.filters button[aria-pressed="true"]{background:#080706;color:#f5f0e7}.gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.gallery-grid article{position:relative;min-height:310px;overflow:hidden;background:#141210}.gallery-grid img{width:100%;height:100%;object-fit:cover;opacity:.72;transition:.25s}.gallery-grid article:hover img{transform:scale(1.025);opacity:.9}.gallery-grid article div{position:absolute;left:0;right:0;bottom:0;padding:45px 20px 18px;background:linear-gradient(transparent,rgba(0,0,0,.88));color:#fff}.gallery-grid span{font-size:.7rem;color:var(--gold-bright)}.gallery-grid h3{margin:6px 0 0;font-size:1.25rem}.video-section{background:#0d0c0b}.video-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.video-placeholder{min-height:260px;display:grid;place-content:center;text-align:center;border:1px solid rgba(185,134,50,.35);background:radial-gradient(circle,rgba(185,134,50,.1),transparent 58%)}.video-placeholder>span{font-size:2.2rem;color:var(--gold-bright)}.video-placeholder h3{margin:18px 0 6px}.video-placeholder p{margin:0;color:#aaa}@media(max-width:800px){.gallery-grid,.video-grid{grid-template-columns:1fr}.gallery-grid article{min-height:360px}}
  </style>
</BaseLayout>
