---
const giftImage = "/images/secondo-regalo.jpg";
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="theme-color" content="#050505" />
    <title>Scopri il secondo regalo</title>
  </head>
  <body>
    <main class="gift-experience" data-gift-experience>
      <section class="unlock-screen" data-unlock-screen aria-labelledby="gift-title">
        <a class="back-link" href="/" aria-label="Torna al sito">← Torna al sito</a>
        <div class="unlock-card">
          <span class="gift-icon" aria-hidden="true">🎁</span>
          <p class="eyebrow">Una sorpresa per te</p>
          <h1 id="gift-title">Scopri il secondo regalo</h1>
          <p class="intro">Inserisci il PIN per sbloccare la sorpresa.</p>

          <form class="pin-form" data-pin-form novalidate>
            <label for="gift-pin">PIN</label>
            <input
              id="gift-pin"
              name="pin"
              type="password"
              inputmode="numeric"
              pattern="[0-9]*"
              maxlength="6"
              autocomplete="off"
              aria-describedby="pin-message"
              placeholder="••••••"
              required
            />
            <button type="submit">Sblocca il regalo</button>
            <p id="pin-message" class="pin-message" data-pin-message aria-live="polite"></p>
          </form>
        </div>
      </section>

      <section class="reveal-screen" data-reveal-screen aria-live="polite" hidden>
        <div class="reveal-copy">
          <span aria-hidden="true">🎉</span>
          <h2>Secondo regalo sbloccato</h2>
          <p>Buon compleanno Arianna ❤️</p>
        </div>
      </section>

      <section class="ticket-screen" data-ticket-screen aria-label="Secondo regalo" hidden>
        <a class="ticket-back" href="/">← Torna al sito</a>
        <button class="zoom-button" type="button" data-zoom-button aria-pressed="false">Ingrandisci</button>
        <div class="ticket-stage" data-ticket-stage>
          <img
            src={giftImage}
            alt="Biglietto per il concerto di Geolier allo Stadio Diego Armando Maradona, 14 giugno 2027"
            data-ticket-image
          />
        </div>
      </section>
    </main>

    <script>
      const CORRECT_PIN = "021242";
      const form = document.querySelector("[data-pin-form]");
      const pinInput = document.querySelector("#gift-pin");
      const message = document.querySelector("[data-pin-message]");
      const unlockScreen = document.querySelector("[data-unlock-screen]");
      const revealScreen = document.querySelector("[data-reveal-screen]");
      const ticketScreen = document.querySelector("[data-ticket-screen]");
      const ticketImage = document.querySelector("[data-ticket-image]");
      const zoomButton = document.querySelector("[data-zoom-button]");

      const showTicket = () => {
        revealScreen.hidden = true;
        ticketScreen.hidden = false;
        requestAnimationFrame(() => ticketScreen.classList.add("is-visible"));
      };

      const unlockGift = () => {
        sessionStorage.setItem("secondGiftUnlocked", "true");
        unlockScreen.hidden = true;
        revealScreen.hidden = false;
        requestAnimationFrame(() => revealScreen.classList.add("is-visible"));
        window.setTimeout(showTicket, 1800);
      };

      if (sessionStorage.getItem("secondGiftUnlocked") === "true") {
        unlockScreen.hidden = true;
        ticketScreen.hidden = false;
        requestAnimationFrame(() => ticketScreen.classList.add("is-visible"));
      } else {
        requestAnimationFrame(() => pinInput?.focus());
      }

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        const value = pinInput.value.trim();

        if (value === CORRECT_PIN) {
          message.textContent = "";
          unlockGift();
          return;
        }

        message.textContent = "PIN non corretto. Riprova.";
        pinInput.setAttribute("aria-invalid", "true");
        pinInput.select();
      });

      pinInput?.addEventListener("input", () => {
        pinInput.value = pinInput.value.replace(/\D/g, "").slice(0, 6);
        pinInput.removeAttribute("aria-invalid");
        message.textContent = "";
      });

      const toggleZoom = () => {
        const zoomed = ticketImage.classList.toggle("is-zoomed");
        zoomButton.setAttribute("aria-pressed", String(zoomed));
        zoomButton.textContent = zoomed ? "Riduci" : "Ingrandisci";
      };

      zoomButton?.addEventListener("click", toggleZoom);
      ticketImage?.addEventListener("dblclick", toggleZoom);
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #050505;
  }

  * { box-sizing: border-box; }

  html,
  body {
    width: 100%;
    min-height: 100%;
    margin: 0;
    background: #050505;
    color: #f7f0e4;
  }

  body { overflow: hidden; }
  [hidden] { display: none !important; }

  button,
  input { font: inherit; }

  .gift-experience,
  .unlock-screen,
  .reveal-screen,
  .ticket-screen {
    width: 100%;
    min-height: 100svh;
  }

  .unlock-screen {
    position: relative;
    display: grid;
    place-items: center;
    padding: max(32px, env(safe-area-inset-top)) 20px max(32px, env(safe-area-inset-bottom));
    background:
      radial-gradient(circle at 50% 40%, rgba(111, 23, 29, 0.18), transparent 38%),
      radial-gradient(circle at 50% 50%, rgba(196, 157, 93, 0.08), transparent 56%),
      #050505;
  }

  .back-link,
  .ticket-back {
    position: fixed;
    z-index: 4;
    top: max(20px, env(safe-area-inset-top));
    left: 20px;
    color: rgba(247, 240, 228, 0.72);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .unlock-card {
    width: min(100%, 460px);
    padding: clamp(34px, 7vw, 56px);
    border: 1px solid rgba(196, 157, 93, 0.24);
    border-radius: 20px;
    background: linear-gradient(145deg, rgba(24, 22, 20, 0.95), rgba(8, 8, 8, 0.98));
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.48);
    text-align: center;
  }

  .gift-icon {
    display: block;
    margin-bottom: 18px;
    font-size: 2rem;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: #c49d5d;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 7vw, 3.25rem);
    font-weight: 500;
    line-height: 1.02;
  }

  .intro {
    margin: 18px auto 28px;
    color: rgba(247, 240, 228, 0.64);
    line-height: 1.55;
  }

  .pin-form {
    display: grid;
    gap: 12px;
  }

  .pin-form label {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .pin-form input {
    width: 100%;
    min-height: 58px;
    border: 1px solid rgba(247, 240, 228, 0.2);
    border-radius: 10px;
    outline: none;
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    font-size: 1.4rem;
    letter-spacing: 0.45em;
    text-align: center;
  }

  .pin-form input:focus {
    border-color: rgba(196, 157, 93, 0.8);
    box-shadow: 0 0 0 3px rgba(196, 157, 93, 0.12);
  }

  .pin-form input[aria-invalid="true"] { border-color: #9f3b43; }

  .pin-form button {
    min-height: 54px;
    border: 1px solid #c49d5d;
    border-radius: 10px;
    background: #c49d5d;
    color: #0a0908;
    cursor: pointer;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pin-message {
    min-height: 1.4em;
    margin: 0;
    color: #e19096;
    font-size: 0.8rem;
  }

  .reveal-screen {
    display: grid;
    place-items: center;
    padding: 24px;
    background: #030303;
    opacity: 0;
    transition: opacity 650ms ease;
  }

  .reveal-screen.is-visible { opacity: 1; }

  .reveal-copy {
    text-align: center;
    transform: translateY(12px) scale(0.98);
    animation: reveal-copy 1.4s ease forwards;
  }

  .reveal-copy span { font-size: 2.2rem; }

  .reveal-copy h2 {
    margin: 16px 0 8px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 8vw, 4.6rem);
    font-weight: 500;
  }

  .reveal-copy p {
    margin: 0;
    color: #c49d5d;
    font-size: clamp(1rem, 3vw, 1.35rem);
  }

  .ticket-screen {
    position: fixed;
    inset: 0;
    display: grid;
    background: #000;
    opacity: 0;
    transition: opacity 700ms ease;
  }

  .ticket-screen.is-visible { opacity: 1; }

  .ticket-stage {
    width: 100%;
    height: 100svh;
    overflow: auto;
    display: grid;
    place-items: center;
    padding: max(64px, env(safe-area-inset-top)) 14px max(24px, env(safe-area-inset-bottom));
    overscroll-behavior: contain;
    touch-action: pinch-zoom;
  }

  .ticket-stage img {
    display: block;
    max-width: 100%;
    max-height: calc(100svh - 90px);
    object-fit: contain;
    transform-origin: center;
    transition: transform 250ms ease;
    user-select: none;
    -webkit-user-drag: none;
  }

  .ticket-stage img.is-zoomed {
    max-width: none;
    max-height: none;
    width: min(1500px, 180vw);
  }

  .zoom-button {
    position: fixed;
    z-index: 4;
    top: max(16px, env(safe-area-inset-top));
    right: 16px;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid rgba(247, 240, 228, 0.28);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.58);
    color: rgba(247, 240, 228, 0.86);
    cursor: pointer;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  @keyframes reveal-copy {
    to { transform: translateY(0) scale(1); }
  }

  @media (max-width: 640px) {
    .unlock-card {
      padding: 34px 22px;
      border-radius: 16px;
    }

    .back-link,
    .ticket-back {
      left: 14px;
      font-size: 0.64rem;
    }

    .ticket-stage img.is-zoomed { width: 190vw; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      scroll-behavior: auto !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
