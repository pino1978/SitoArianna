---
const giftImage = "/images/Screenshot_20260722_221351_Adobe%20Acrobat(1)(1)(1).jpg";
const soundtrack = "/images/Geolier%2C%20Ultimo%20-%20L'ULTIMA%20POESIA%20(Official%20Video).mp3";
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="theme-color" content="#050505" />
    <title>Scopri il secondo regalo</title>
  </head>
  <body>
    <main>
      <section class="screen unlock" data-unlock>
        <a class="back" href="/">← Torna al sito</a>
        <div class="card">
          <span class="gift" aria-hidden="true">🎁</span>
          <p class="eyebrow">Una sorpresa per te</p>
          <h1>Scopri il secondo regalo</h1>
          <p class="intro">Inserisci il PIN per sbloccare la sorpresa.</p>
          <form data-form novalidate>
            <label for="gift-pin">PIN</label>
            <input id="gift-pin" type="password" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="off" placeholder="••••••" required />
            <button type="submit">Sblocca il regalo</button>
            <p class="message" data-message aria-live="polite"></p>
          </form>
        </div>
      </section>

      <section class="screen reveal" data-reveal hidden>
        <div class="beam" aria-hidden="true"></div>
        <div class="flash" aria-hidden="true"></div>
        <div class="reveal-copy">
          <span class="unlock-mark" aria-hidden="true">✦</span>
          <p class="reveal-kicker">ACCESSO CONFERMATO</p>
          <h2>Secondo regalo sbloccato</h2>
          <p>Buon compleanno Arianna ❤️</p>
        </div>
      </section>

      <section class="ticket" data-ticket hidden>
        <audio src={soundtrack} preload="auto" data-audio></audio>
        <div class="ambient ambient-one" aria-hidden="true"></div>
        <div class="ambient ambient-two" aria-hidden="true"></div>
        <a class="back" href="/">← Torna al sito</a>
        <button class="zoom" type="button" data-zoom aria-pressed="false">Ingrandisci</button>
        <div class="stage">
          <div class="ticket-frame" data-ticket-frame>
            <div class="ticket-glow" aria-hidden="true"></div>
            <img src={giftImage} alt="Biglietto per il concerto di Geolier allo Stadio Diego Armando Maradona, 14 giugno 2027" data-image />
          </div>
        </div>
        <div class="spotlight-darkness" aria-hidden="true"></div>
        <div class="spotlight-haze" aria-hidden="true"></div>
      </section>
    </main>

    <script>
      const CORRECT_PIN = "021242";
      const unlock = document.querySelector("[data-unlock]");
      const reveal = document.querySelector("[data-reveal]");
      const ticket = document.querySelector("[data-ticket]");
      const frame = document.querySelector("[data-ticket-frame]");
      const form = document.querySelector("[data-form]");
      const input = document.querySelector("#gift-pin");
      const message = document.querySelector("[data-message]");
      const image = document.querySelector("[data-image]");
      const zoom = document.querySelector("[data-zoom]");
      const audio = document.querySelector("[data-audio]");
      let fadeTimer;

      const syncSpotlightToTicket = () => {
        if (!ticket || !frame) return;
        const rect = frame.getBoundingClientRect();
        const edge = 6;
        ticket.style.setProperty("--ticket-left", `${Math.max(edge, rect.left + edge)}px`);
        ticket.style.setProperty("--ticket-right", `${Math.min(window.innerWidth - edge, rect.right - edge)}px`);
        ticket.style.setProperty("--ticket-top", `${Math.max(edge, rect.top + edge)}px`);
        ticket.style.setProperty("--ticket-bottom", `${Math.min(window.innerHeight - edge, rect.bottom - edge)}px`);
      };

      const playUnlockSound = () => {
        try {
          const AudioContextClass = window.AudioContext || window.webkitAudioContext;
          if (!AudioContextClass) return;
          const ctx = new AudioContextClass();
          const now = ctx.currentTime;
          const master = ctx.createGain();
          master.gain.setValueAtTime(0.0001, now);
          master.gain.exponentialRampToValueAtTime(0.22, now + 0.03);
          master.gain.exponentialRampToValueAtTime(0.0001, now + 1.9);
          master.connect(ctx.destination);
          const tone = (frequency, start, duration, type = "sine", volume = 0.18) => {
            const oscillator = ctx.createOscillator();
            const gain = ctx.createGain();
            oscillator.type = type;
            oscillator.frequency.setValueAtTime(frequency, now + start);
            oscillator.frequency.exponentialRampToValueAtTime(frequency * 1.35, now + start + duration);
            gain.gain.setValueAtTime(0.0001, now + start);
            gain.gain.exponentialRampToValueAtTime(volume, now + start + 0.025);
            gain.gain.exponentialRampToValueAtTime(0.0001, now + start + duration);
            oscillator.connect(gain);
            gain.connect(master);
            oscillator.start(now + start);
            oscillator.stop(now + start + duration + 0.05);
          };
          tone(180, 0, 0.65, "sine", 0.28);
          tone(360, 0.08, 0.5, "triangle", 0.16);
          tone(720, 0.28, 0.42, "sine", 0.1);
          const buffer = ctx.createBuffer(1, ctx.sampleRate * 0.9, ctx.sampleRate);
          const data = buffer.getChannelData(0);
          for (let i = 0; i < data.length; i += 1) data[i] = (Math.random() * 2 - 1) * (1 - i / data.length);
          const noise = ctx.createBufferSource();
          const filter = ctx.createBiquadFilter();
          const gain = ctx.createGain();
          noise.buffer = buffer;
          filter.type = "lowpass";
          filter.frequency.setValueAtTime(1200, now);
          filter.frequency.exponentialRampToValueAtTime(180, now + 0.85);
          gain.gain.setValueAtTime(0.0001, now);
          gain.gain.exponentialRampToValueAtTime(0.12, now + 0.05);
          gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.85);
          noise.connect(filter);
          filter.connect(gain);
          gain.connect(master);
          noise.start(now);
          noise.stop(now + 0.9);
          window.setTimeout(() => ctx.close(), 2300);
        } catch (_) {}
      };

      const startSoundtrack = () => {
        if (!audio) return;
        window.clearInterval(fadeTimer);
        audio.pause();
        audio.currentTime = 0;
        audio.volume = 0;
        audio.play()?.catch(() => {});
        window.setTimeout(() => {
          fadeTimer = window.setInterval(() => {
            if (audio.volume >= 0.62) {
              audio.volume = 0.62;
              window.clearInterval(fadeTimer);
              return;
            }
            audio.volume = Math.min(0.62, audio.volume + 0.018);
          }, 120);
        }, 1000);
      };

      const resetExperience = () => {
        window.clearInterval(fadeTimer);
        audio?.pause();
        if (audio) { audio.currentTime = 0; audio.volume = 0; }
        unlock.hidden = false;
        reveal.hidden = true;
        ticket.hidden = true;
        reveal.classList.remove("visible");
        ticket.classList.remove("visible");
        image?.classList.remove("zoomed");
        zoom?.setAttribute("aria-pressed", "false");
        if (zoom) zoom.textContent = "Ingrandisci";
        if (input) input.value = "";
        if (message) message.textContent = "";
        requestAnimationFrame(() => input?.focus());
      };

      resetExperience();
      window.addEventListener("pageshow", resetExperience);
      window.addEventListener("resize", syncSpotlightToTicket);
      image?.addEventListener("load", syncSpotlightToTicket);

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        const value = input.value.trim();
        if (value !== CORRECT_PIN) {
          message.textContent = "PIN non corretto. Riprova.";
          input.setAttribute("aria-invalid", "true");
          input.select();
          return;
        }
        message.textContent = "";
        navigator.vibrate?.([70, 45, 120]);
        playUnlockSound();
        startSoundtrack();
        unlock.hidden = true;
        reveal.hidden = false;
        requestAnimationFrame(() => reveal.classList.add("visible"));
        window.setTimeout(() => {
          reveal.hidden = true;
          ticket.hidden = false;
          requestAnimationFrame(() => {
            syncSpotlightToTicket();
            ticket.classList.add("visible");
          });
        }, 3100);
      });

      input?.addEventListener("input", () => {
        input.value = input.value.replace(/\D/g, "").slice(0, 6);
        input.removeAttribute("aria-invalid");
        message.textContent = "";
      });

      zoom?.addEventListener("click", () => {
        const active = image.classList.toggle("zoomed");
        zoom.setAttribute("aria-pressed", String(active));
        zoom.textContent = active ? "Riduci" : "Ingrandisci";
        requestAnimationFrame(syncSpotlightToTicket);
      });
    </script>
  </body>
</html>

<style is:global>
  @property --spot-x { syntax: "<length>"; inherits: false; initial-value: 90vw; }
  @property --spot-y { syntax: "<length>"; inherits: false; initial-value: 8vh; }
  @property --spot-core { syntax: "<length>"; inherits: false; initial-value: 8vmin; }
  @property --spot-falloff { syntax: "<length>"; inherits: false; initial-value: 22vmin; }
  :root { color-scheme: dark; font-family: Inter, ui-sans-serif, system-ui, sans-serif; background: #050505; }
  * { box-sizing: border-box; }
  html, body { width: 100%; min-height: 100%; margin: 0; background: #050505; color: #f7f0e4; }
  body { overflow: hidden; }
  [hidden] { display: none !important; }
  button, input { font: inherit; }
  .screen, .ticket { width: 100%; min-height: 100svh; }
  .unlock { display: grid; place-items: center; padding: max(32px, env(safe-area-inset-top)) 20px max(32px, env(safe-area-inset-bottom)); background: radial-gradient(circle at 50% 40%, rgba(111,23,29,.18), transparent 38%), radial-gradient(circle at 50% 50%, rgba(196,157,93,.08), transparent 56%), #050505; }
  .back { position: fixed; z-index: 8; top: max(20px, env(safe-area-inset-top)); left: 20px; color: rgba(247,240,228,.72); font-size: .72rem; letter-spacing: .08em; text-decoration: none; text-transform: uppercase; }
  .card { width: min(100%, 460px); padding: clamp(34px, 7vw, 56px); border: 1px solid rgba(196,157,93,.24); border-radius: 20px; background: linear-gradient(145deg, rgba(24,22,20,.95), rgba(8,8,8,.98)); box-shadow: 0 30px 80px rgba(0,0,0,.48); text-align: center; }
  .gift { display: block; margin-bottom: 18px; font-size: 2rem; }
  .eyebrow { margin: 0 0 10px; color: #c49d5d; font-size: .68rem; letter-spacing: .2em; text-transform: uppercase; }
  h1, h2 { font-family: Georgia, "Times New Roman", serif; font-weight: 500; }
  h1 { margin: 0; font-size: clamp(2rem, 7vw, 3.25rem); line-height: 1.02; }
  .intro { margin: 18px auto 28px; color: rgba(247,240,228,.64); line-height: 1.55; }
  form { display: grid; gap: 12px; }
  form label { font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; }
  form input { width: 100%; min-height: 58px; border: 1px solid rgba(247,240,228,.2); border-radius: 10px; outline: none; background: rgba(255,255,255,.04); color: #fff; font-size: 1.4rem; letter-spacing: .45em; text-align: center; }
  form button { min-height: 54px; border: 1px solid #c49d5d; border-radius: 10px; background: #c49d5d; color: #0a0908; cursor: pointer; font-size: .72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; }
  .message { min-height: 1.4em; margin: 0; color: #e19096; font-size: .8rem; }
  .reveal { position: relative; display: grid; place-items: center; overflow: hidden; padding: 24px; background: radial-gradient(circle at 50% 50%, rgba(100,9,18,.18), transparent 34%), #020202; text-align: center; opacity: 0; }
  .reveal.visible { animation: reveal-screen 3.1s ease forwards; }
  .reveal-copy { position: relative; z-index: 3; opacity: 0; transform: translateY(16px) scale(.97); }
  .reveal.visible .reveal-copy { animation: reveal-copy 1.9s .45s cubic-bezier(.2,.8,.2,1) forwards; }
  .unlock-mark { display: block; color: #c49d5d; font-size: 2.3rem; text-shadow: 0 0 28px rgba(196,157,93,.55); }
  .reveal-kicker { margin: 14px 0 10px !important; color: #8d202b !important; font-size: .66rem !important; font-weight: 700; letter-spacing: .28em; }
  .reveal h2 { margin: 0 0 10px; font-size: clamp(2rem, 8vw, 4.6rem); text-shadow: 0 0 34px rgba(255,255,255,.08); }
  .reveal p { margin: 0; color: #c49d5d; font-size: clamp(1rem, 3vw, 1.35rem); }
  .beam { position: absolute; inset: -30% auto -30% -55%; width: 34%; background: linear-gradient(90deg, transparent, rgba(128,16,28,.4), rgba(230,75,87,.14), transparent); filter: blur(10px); transform: skewX(-18deg); opacity: 0; }
  .reveal.visible .beam { animation: beam-pass 1.9s .15s ease-out forwards; }
  .flash { position: absolute; inset: 0; background: #7b101b; opacity: 0; mix-blend-mode: screen; }
  .reveal.visible .flash { animation: flash 1.5s 1.85s ease-out forwards; }
  .ticket { --ticket-left: 6px; --ticket-right: calc(100vw - 6px); --ticket-top: 6px; --ticket-bottom: calc(100vh - 6px); position: fixed; inset: 0; display: grid; overflow: hidden; background: #000; opacity: 0; }
  .ticket.visible { animation: ticket-screen .45s ease forwards; }
  .ambient { position: absolute; border-radius: 999px; filter: blur(70px); opacity: 0; pointer-events: none; }
  .ticket.visible .ambient { animation: ambient-in 2.8s 15.5s ease forwards; }
  .ambient-one { width: 38vw; height: 38vw; left: -12vw; top: 8vh; background: #6d111b; }
  .ambient-two { width: 30vw; height: 30vw; right: -10vw; bottom: 2vh; background: #8c6a38; }
  .stage { position: relative; z-index: 2; width: 100%; height: 100svh; overflow: auto; display: grid; place-items: center; padding: max(64px, env(safe-area-inset-top)) 14px max(24px, env(safe-area-inset-bottom)); touch-action: pinch-zoom; perspective: 1200px; }
  .ticket-frame { position: relative; opacity: 1; transform: scale(.985); filter: brightness(.72) saturate(.78) blur(2px); overflow: hidden; border-radius: 3px; box-shadow: 0 30px 90px rgba(0,0,0,.8); }
  .ticket.visible .ticket-frame { animation: artifact-arrive 1.4s .15s cubic-bezier(.22,.7,.2,1) forwards, artifact-settle 2.8s 15.8s ease forwards; }
  .stage img { display: block; max-width: 100%; max-height: calc(100svh - 90px); object-fit: contain; transform-origin: center; transition: transform 250ms ease; user-select: none; }
  .stage img.zoomed { max-width: none; max-height: none; width: min(1500px, 180vw); }
  .spotlight-darkness { position: fixed; z-index: 6; inset: 0; pointer-events: none; opacity: 1; background: radial-gradient(circle at var(--spot-x) var(--spot-y), transparent 0 var(--spot-core), rgba(0,0,0,.2) calc(var(--spot-core) + 4vmin), rgba(0,0,0,.992) var(--spot-falloff)); }
  .ticket.visible .spotlight-darkness { animation: spotlight-search 17.5s .25s cubic-bezier(.45,0,.22,1) forwards; }
  .spotlight-haze { position: fixed; z-index: 7; width: min(36vw,36vh); aspect-ratio: 1; left: calc(var(--ticket-right) - min(18vw,18vh)); top: calc(var(--ticket-top) - min(18vw,18vh)); border-radius: 50%; pointer-events: none; opacity: 0; background: radial-gradient(circle, rgba(255,242,215,.2) 0, rgba(196,157,93,.09) 30%, transparent 74%); filter: blur(9px); mix-blend-mode: screen; }
  .ticket.visible .spotlight-haze { animation: haze-search 16.3s .35s cubic-bezier(.45,0,.22,1) forwards; }
  .ticket-glow { position: absolute; z-index: 5; inset: -10%; pointer-events: none; opacity: 0; background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,.02) 43%, rgba(196,157,93,.28) 50%, rgba(255,255,255,.05) 57%, transparent 70%); transform: translateX(-130%); mix-blend-mode: screen; }
  .ticket.visible .ticket-glow { animation: ticket-glow 3s 16.4s ease-in-out forwards; }
  .zoom { position: fixed; z-index: 8; top: max(16px, env(safe-area-inset-top)); right: 16px; min-height: 38px; padding: 0 14px; border: 1px solid rgba(247,240,228,.28); border-radius: 999px; background: rgba(0,0,0,.58); color: rgba(247,240,228,.86); cursor: pointer; font-size: .68rem; letter-spacing: .08em; text-transform: uppercase; opacity: 0; }
  .ticket.visible .zoom { animation: controls-in .9s 18.2s ease forwards; }
  @keyframes reveal-screen { 0% { opacity: 0; } 22%, 88% { opacity: 1; } 100% { opacity: 1; } }
  @keyframes reveal-copy { to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes beam-pass { 0% { left: -55%; opacity: 0; } 18% { opacity: 1; } 100% { left: 125%; opacity: 0; } }
  @keyframes flash { 0%, 70% { opacity: 0; } 82% { opacity: .42; } 100% { opacity: 0; } }
  @keyframes ticket-screen { to { opacity: 1; } }
  @keyframes artifact-arrive { 0% { transform: scale(.985); filter: brightness(.62) saturate(.74) blur(2px); } 100% { transform: scale(1); filter: brightness(.72) saturate(.78) blur(2px); } }
  @keyframes artifact-settle { to { filter: brightness(1) saturate(1) blur(0); box-shadow: 0 30px 90px rgba(0,0,0,.68), 0 0 0 1px rgba(255,255,255,.05); } }
  @keyframes spotlight-search {
    0% { --spot-x: var(--ticket-right); --spot-y: var(--ticket-top); --spot-core: 8vmin; --spot-falloff: 22vmin; opacity: 1; }
    10% { --spot-x: calc(var(--ticket-left) + (var(--ticket-right) - var(--ticket-left)) * .72); --spot-y: var(--ticket-top); }
    20% { --spot-x: calc(var(--ticket-left) + (var(--ticket-right) - var(--ticket-left)) * .42); --spot-y: var(--ticket-top); --spot-core: 7.5vmin; --spot-falloff: 21vmin; }
    30% { --spot-x: var(--ticket-left); --spot-y: var(--ticket-top); }
    42% { --spot-x: var(--ticket-left); --spot-y: calc(var(--ticket-top) + (var(--ticket-bottom) - var(--ticket-top)) * .38); }
    54% { --spot-x: var(--ticket-left); --spot-y: var(--ticket-bottom); --spot-core: 7vmin; --spot-falloff: 21vmin; }
    65% { --spot-x: calc(var(--ticket-left) + (var(--ticket-right) - var(--ticket-left)) * .38); --spot-y: var(--ticket-bottom); }
    76% { --spot-x: var(--ticket-right); --spot-y: var(--ticket-bottom); --spot-core: 7vmin; --spot-falloff: 22vmin; }
    86% { --spot-x: var(--ticket-right); --spot-y: calc(var(--ticket-top) + (var(--ticket-bottom) - var(--ticket-top)) * .58); }
    92% { --spot-x: var(--ticket-right); --spot-y: var(--ticket-top); --spot-core: 9vmin; --spot-falloff: 26vmin; opacity: .95; }
    96% { --spot-x: 50vw; --spot-y: var(--ticket-top); --spot-core: 11vmin; --spot-falloff: 32vmin; opacity: .88; }
    98.5% { --spot-x: 50vw; --spot-y: 50vh; --spot-core: 28vmin; --spot-falloff: 56vmin; opacity: .7; }
    100% { --spot-x: 50vw; --spot-y: 50vh; --spot-core: 60vmax; --spot-falloff: 75vmax; opacity: 0; }
  }
  @keyframes haze-search {
    0% { left: calc(var(--ticket-right) - min(18vw,18vh)); top: calc(var(--ticket-top) - min(18vw,18vh)); opacity: 0; transform: scale(.78); }
    8% { opacity: .68; }
    30% { left: calc(var(--ticket-left) - min(18vw,18vh)); top: calc(var(--ticket-top) - min(18vw,18vh)); transform: scale(.74); }
    55% { left: calc(var(--ticket-left) - min(18vw,18vh)); top: calc(var(--ticket-bottom) - min(18vw,18vh)); transform: scale(.78); }
    80% { left: calc(var(--ticket-right) - min(18vw,18vh)); top: calc(var(--ticket-bottom) - min(18vw,18vh)); transform: scale(.8); }
    92% { left: calc(var(--ticket-right) - min(18vw,18vh)); top: calc(var(--ticket-top) - min(18vw,18vh)); transform: scale(.88); opacity: .55; }
    100% { left: 32vw; top: 32vh; transform: scale(3.6); opacity: 0; }
  }
  @keyframes ticket-glow { 0% { transform: translateX(-130%); opacity: 0; } 20% { opacity: .75; } 100% { transform: translateX(130%); opacity: 0; } }
  @keyframes ambient-in { to { opacity: .1; } }
  @keyframes controls-in { to { opacity: 1; } }
  @media (max-width: 640px) { .card { padding: 34px 22px; border-radius: 16px; } .back { left: 14px; font-size: .64rem; } .stage img.zoomed { width: 190vw; } .ambient { filter: blur(48px); } .spotlight-haze { width: min(46vw,46vh); } }
  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: .01ms !important; transition-duration: .01ms !important; } }
</style>
